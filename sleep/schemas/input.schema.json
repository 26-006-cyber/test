{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "sleep-planner-input.schema.json",
  "title": "Sleep Planner Input",
  "type": "object",
  "required": ["planDate"],
  "additionalProperties": false,
  "properties": {
    "planDate": {
      "type": "string",
      "description": "Planning date in local time (YYYY-MM-DD).",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ageYears": { "type": "number", "minimum": 0, "maximum": 120 },
        "gender": { "type": "string" }
      }
    },
    "habit": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "preferredBedTime": {
          "type": "string",
          "description": "Preferred bedtime (HH:MM).",
          "pattern": "^\\d{1,2}:\\d{2}$"
        },
        "selfReportedSleepNeedHours": {
          "type": "number",
          "minimum": 4,
          "maximum": 16
        }
      }
    },
    "preferences": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "defaultWakeTime": { "type": "string", "pattern": "^\\d{1,2}:\\d{2}$" },
        "prepBufferMinutes": { "type": "number", "minimum": 0, "maximum": 240 },
        "orientation": { "type": "string", "enum": ["early", "balanced", "late"] },
        "searchStepMinutes": { "type": "number", "minimum": 5, "maximum": 60 },
        "searchRadiusMinutes": { "type": "number", "minimum": 60, "maximum": 360 }
      }
    },
    "tasks": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "title": "Fixed (weekly) task",
            "type": "object",
            "required": ["type", "startTime", "endTime"],
            "additionalProperties": false,
            "properties": {
              "type": { "const": "fixed" },
              "id": { "type": "string" },
              "title": { "type": "string" },
              "period": { "type": "string", "enum": ["daily", "weekly", "monthly", "yearly"], "default": "weekly" },
              "weekdays": {
                "type": "array",
                "items": { "type": "integer", "minimum": 0, "maximum": 6 },
                "minItems": 1
              },
              "dayOfMonth": { "type": "integer", "minimum": 1, "maximum": 31 },
              "monthOfYear": { "type": "integer", "minimum": 1, "maximum": 12 },
              "dayOfYear": { "type": "integer", "minimum": 1, "maximum": 31 },
              "startTime": { "type": "string", "pattern": "^\\d{1,2}:\\d{2}$" },
              "endTime": { "type": "string", "pattern": "^\\d{1,2}:\\d{2}$" },
              "isHard": { "type": "boolean", "default": true },
              "priority": { "type": "number", "minimum": 0, "maximum": 1 }
            }
          },
          {
            "title": "Once (scheduled) task",
            "type": "object",
            "required": ["type", "start", "end"],
            "additionalProperties": false,
            "properties": {
              "type": { "const": "once" },
              "id": { "type": "string" },
              "title": { "type": "string" },
              "start": { "type": "string" },
              "end": { "type": "string" },
              "isHard": { "type": "boolean", "default": true },
              "priority": { "type": "number", "minimum": 0, "maximum": 1 }
            }
          },
          {
            "title": "Deadline task",
            "type": "object",
            "required": ["type", "due"],
            "additionalProperties": false,
            "properties": {
              "type": { "const": "deadline" },
              "id": { "type": "string" },
              "title": { "type": "string" },
              "due": { "type": "string" },
              "estimatedMinutes": { "type": "number", "minimum": 0, "maximum": 10080 },
              "urgency": { "type": "number", "minimum": 0, "maximum": 1 }
            }
          }
        ]
      }
    },
    "sleepHistory": {
      "type": "array",
      "description": "Optional sleep episodes from manual input or sensors (actigraphy).",
      "items": {
        "type": "object",
        "required": ["start", "end"],
        "additionalProperties": false,
        "properties": {
          "start": { "type": "string" },
          "end": { "type": "string" }
        }
      }
    }
  }
}

